{
  "name": "portfolio",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build && tsc -p tsconfig.node.json",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.node.json",
    "start": "node client/server/docs/index.js",
    "preview": "vite preview",
    "lint:ts": "eslint client/**/*.{ts,tsx}",
    "prepare": "husky"
  },
  "dependencies": {
    "express": "^4.18.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "stylelint": "^16.0.0",
    "stylelint-config-recommended-scss": "^14.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  },
  "volta": {
    "node": "20.10.0"
  }
}
